{
  "name": "linkedin.aladdyn",
  "version": "1.0.0",
  "description": "LinkedIn automation engine for Aladdyn",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc && tsc-alias && prisma generate",
    "start": "node dist/server.js",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "queue:ui": "tsx src/jobs/bullBoard.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@bull-board/api": "^5.0.0",
    "@bull-board/express": "^5.0.0",
    "@prisma/client": "^5.0.0",
    "axios": "^1.6.0",
    "bullmq": "^5.4.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.0",
    "openai": "^4.40.0",
    "playwright": "^1.40.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.11.0",
    "@types/uuid": "^9.0.7",
    "prisma": "^5.0.0",
    "tsc-alias": "^1.8.8",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
